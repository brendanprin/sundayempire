generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum LeaguePhase {
  PRESEASON_SETUP
  ROOKIE_DRAFT
  AUCTION_MAIN_DRAFT
  REGULAR_SEASON
  PLAYOFFS
  OFFSEASON_ROLLOVER
  TAG_OPTION_COMPLIANCE
}

enum SeasonStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TransitionStatus {
  SUCCESS
  FAILED
  ROLLED_BACK
}

enum TeamSlotType {
  STARTER
  BENCH
  IR
  TAXI
}

enum Position {
  QB
  RB
  WR
  TE
  K
  DST
}

enum DraftType {
  STARTUP
  ROOKIE
  VETERAN_AUCTION
}

enum DraftStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum DraftPickStatus {
  PENDING
  SELECTED
  PASSED
  FORFEITED
}

enum DraftOrderSourceType {
  FUTURE_PICK
  MANUAL
  BONUS
}

enum DraftSelectionOutcome {
  SELECTED
  PASSED
  FORFEITED
}

enum AuctionSessionMode {
  STANDARD
  EMERGENCY_FILL_IN
}

enum AuctionPlayerPoolEntryStatus {
  ELIGIBLE
  OPEN_BIDDING
  BLIND_BIDDING
  AWARDED
  EXPIRED
  WITHDRAWN
  REOPENED
}

enum AuctionPoolReviewStatus {
  PENDING_REVIEW
  FINALIZED
}

enum AuctionPoolExclusionReason {
  ACTIVE_CONTRACT
  ROSTERED
  RESTRICTED
  ALREADY_AWARDED
  NOT_REQUESTED_FOR_EMERGENCY_FILL_IN
  EMERGENCY_POOL_LIMIT
}

enum AuctionBidType {
  OPEN
  BLIND
}

enum AuctionBidStatus {
  ACTIVE
  OUTBID
  WON
  LOST
  CANCELED
}

enum AuctionAwardStatus {
  FINALIZED
  VOIDED
}

enum HostPlatformSyncJobType {
  ROSTER_IMPORT
  TRANSACTION_IMPORT
  FULL_SYNC
}

enum HostPlatformSyncJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  CANCELED
}

enum HostPlatformSyncTrigger {
  MANUAL
  CSV_UPLOAD
  ADAPTER_PULL
}

enum PlayerRefreshJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  CANCELED
}

enum PlayerRefreshChangeType {
  NEW
  UPDATED
  UNCHANGED
  INVALID
  AMBIGUOUS
  DUPLICATE_SUSPECT
}

enum PlayerRefreshChangeReviewStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum SyncMismatchType {
  ROSTER_MISSING_IN_APP
  ROSTER_MISSING_IN_HOST
  ROSTER_TEAM_DIFFERENCE
  ROSTER_STATUS_DIFFERENCE
  TRANSACTION_MISSING_IN_APP
  TRANSACTION_MISSING_IN_HOST
  TRANSACTION_TEAM_DIFFERENCE
  TRANSACTION_SUMMARY_DIFFERENCE
}

enum SyncMismatchSeverity {
  INFO
  WARNING
  HIGH_IMPACT
}

enum SyncMismatchStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum SyncMismatchResolutionType {
  ACCEPT_HOST_PLATFORM
  KEEP_DYNASTY_TRUTH
  DISMISS_FALSE_POSITIVE
  ESCALATE_TO_COMPLIANCE
}

enum TradeStatus {
  PROPOSED
  APPROVED
  PROCESSED
  REJECTED
  CANCELED
}

enum TradeAssetType {
  PLAYER
  PICK
}

enum TradeProposalStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  DECLINED
  REVIEW_PENDING
  REVIEW_APPROVED
  REVIEW_REJECTED
  PROCESSED
  CANCELED
}

enum TradeEvaluationOutcome {
  PASS
  PASS_WITH_WARNING
  FAIL_HARD_BLOCK
  FAIL_REQUIRES_COMMISSIONER
}

enum TradeEvaluationTrigger {
  BUILDER_VALIDATE
  SUBMIT
  COUNTERPARTY_RESPONSE
  COMMISSIONER_REVIEW
}

enum PlatformRole {
  ADMIN
  USER
}

enum LeagueRole {
  COMMISSIONER
  MEMBER
}

enum InviteDeliveryState {
  SENT
  CAPTURED
  LOGGED
  FAILED
  NOT_CONFIGURED
}

enum TeamMembershipType {
  PRIMARY_MANAGER
  CO_MANAGER
}

enum RosterStatus {
  ACTIVE
  IR
  RELEASED
  MIRRORED_ONLY
}

enum AcquisitionType {
  AUCTION
  ROOKIE_DRAFT
  WAIVER
  TRADE
  TAG
  MANUAL
  EMERGENCY_FILL_IN
}

enum ContractStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  TERMINATED
  TAGGED
}

enum ContractOptionDecisionType {
  EXERCISE
  DECLINE
  EXPIRED_UNRESOLVED
}

enum DeadCapSourceEventType {
  CUT
  OVERRIDE_ADJUSTMENT
}

enum ComplianceIssueSource {
  RULE_ENGINE
  DEADLINE
  MANUAL
  SYNC
}

enum ComplianceIssueType {
  ROSTER
  LINEUP
  CAP
  CONTRACT
  FRANCHISE_TAG
  IR
  DEADLINE
  LIFECYCLE
  MANUAL
  SYNC
}

enum ComplianceIssueSeverity {
  WARNING
  ERROR
  CRITICAL
}

enum ComplianceIssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  WAIVED
}

enum ComplianceDueAtBasis {
  PHASE_WINDOW
  DEADLINE
  SCORING_WINDOW
  MANUAL
}

enum ComplianceActionType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  REMEDIATION_APPLIED
  REMEDIATION_SUBMITTED
  REMEDIATION_REVIEWED
  RESOLVED
  NOTIFICATION_TRIGGERED
}

enum CommissionerOverrideType {
  PHASE_TRANSITION
  EMERGENCY_FIX
  CONTRACT_CREATE
  CONTRACT_UPDATE
  ISSUE_WAIVER
  MANUAL_RULING
}

enum CommissionerOverrideStatus {
  APPLIED
  REVERSED
}

enum TransactionType {
  ADD
  DROP
  WAIVER_ADD
  WAIVER_DROP
  TRADE_IN
  TRADE_OUT
  CONTRACT_CREATE
  CONTRACT_UPDATE
  CONTRACT_OPTION_EXERCISED
  FRANCHISE_TAG_APPLIED
  ROSTER_MOVE
  PICK_TRANSFER
  COMMISSIONER_OVERRIDE
  OFFSEASON_ROLLOVER
}

model League {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seasons                  Season[]                 @relation("LeagueSeasons")
  teams                    Team[]
  memberships              LeagueMembership[]
  invites                  LeagueInvite[]
  rulesets                 LeagueRuleSet[]
  drafts                   Draft[]
  picks                    FuturePick[]
  auctionPlayerPoolEntries AuctionPlayerPoolEntry[] @relation("LeagueAuctionPlayerPoolEntries")
  auctionPlayerPoolExclusions AuctionPlayerPoolExclusion[] @relation("LeagueAuctionPlayerPoolExclusions")
  auctionBids              AuctionBid[]             @relation("LeagueAuctionBids")
  auctionAwards            AuctionAward[]           @relation("LeagueAuctionAwards")
  blindTieResolutions      AuctionBlindTieResolution[] @relation("LeagueBlindTieResolutions")
  hostPlatformSyncJobs     HostPlatformSyncJob[]    @relation("LeagueHostPlatformSyncJobs")
  playerRefreshJobs        PlayerRefreshJob[]
  playerRefreshChanges     PlayerRefreshChange[]
  playerSeasonSnapshots    PlayerSeasonSnapshot[]
  syncMismatches           SyncMismatch[]           @relation("LeagueSyncMismatches")
  trades                   Trade[]
  tradeProposals           TradeProposal[]          @relation("LeagueTradeProposals")
  tradeEvaluations         TradeEvaluation[]        @relation("LeagueTradeEvaluations")
  activityEvents           ActivityEvent[]          @relation("LeagueActivityEvents")
  transactions             Transaction[]
  deadlines                LeagueDeadline[]
  phaseTransitions         LeaguePhaseTransition[]
  deadCapCharges           DeadCapCharge[]
  complianceIssues         ComplianceIssue[]        @relation("LeagueComplianceIssues")
  commissionerOverrides    CommissionerOverride[]   @relation("LeagueCommissionerOverrides")
  notifications            Notification[]           @relation("LeagueNotifications")
  pilotEvents              PilotEvent[]
  pilotFeedback            PilotFeedback[]
  notificationReadStates   NotificationReadState[]
}

model Season {
  id                 String       @id @default(cuid())
  leagueId           String
  year               Int
  status             SeasonStatus @default(ACTIVE)
  phase              LeaguePhase  @default(PRESEASON_SETUP)
  openedAt           DateTime?
  closedAt           DateTime?
  sourceSeasonId     String?
  regularSeasonWeeks Int          @default(13)
  playoffStartWeek   Int          @default(14)
  playoffEndWeek     Int          @default(16)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  league                           League                   @relation("LeagueSeasons", fields: [leagueId], references: [id], onDelete: Cascade)
  sourceSeason                     Season?                  @relation("SeasonLineage", fields: [sourceSeasonId], references: [id], onDelete: SetNull)
  derivedSeasons                   Season[]                 @relation("SeasonLineage")
  deadlines                        LeagueDeadline[]
  phaseTransitions                 LeaguePhaseTransition[]
  teamStates                       TeamSeasonState[]
  rosters                          RosterSlot[]
  rosterAssignments                RosterAssignment[]
  draftOrderEntries                DraftOrderEntry[]        @relation("SeasonDraftOrderEntries")
  draftPicks                       DraftPick[]              @relation("SeasonDraftPicks")
  auctionPlayerPoolEntries         AuctionPlayerPoolEntry[] @relation("SeasonAuctionPlayerPoolEntries")
  auctionPlayerPoolExclusions      AuctionPlayerPoolExclusion[] @relation("SeasonAuctionPlayerPoolExclusions")
  auctionBids                      AuctionBid[]             @relation("SeasonAuctionBids")
  auctionAwards                    AuctionAward[]           @relation("SeasonAuctionAwards")
  blindTieResolutions              AuctionBlindTieResolution[] @relation("SeasonBlindTieResolutions")
  hostPlatformSyncJobs             HostPlatformSyncJob[]    @relation("SeasonHostPlatformSyncJobs")
  playerRefreshJobs                PlayerRefreshJob[]
  playerRefreshChanges             PlayerRefreshChange[]
  playerSeasonSnapshots            PlayerSeasonSnapshot[]
  syncMismatches                   SyncMismatch[]           @relation("SeasonSyncMismatches")
  contractSeasonLedgers            ContractSeasonLedger[]   @relation("SeasonContractSeasonLedgers")
  franchiseTagUsages               FranchiseTagUsage[]      @relation("SeasonFranchiseTagUsages")
  frozenSnapshotFranchiseTagUsages FranchiseTagUsage[]      @relation("FrozenSnapshotSeasonFranchiseTagUsages")
  contractOptionDecisions          ContractOptionDecision[] @relation("SeasonContractOptionDecisions")
  deadCapCharges                   DeadCapCharge[]          @relation("AppliesToSeasonDeadCapCharges")
  complianceIssues                 ComplianceIssue[]        @relation("SeasonComplianceIssues")
  commissionerOverrides            CommissionerOverride[]   @relation("SeasonCommissionerOverrides")
  notifications                    Notification[]           @relation("SeasonNotifications")
  contracts                        Contract[]
  capPenalties                     CapPenalty[]
  drafts                           Draft[]
  trades                           Trade[]
  tradeProposals                   TradeProposal[]          @relation("SeasonTradeProposals")
  tradeEvaluations                 TradeEvaluation[]        @relation("SeasonTradeEvaluations")
  activityEvents                   ActivityEvent[]          @relation("SeasonActivityEvents")
  transactions                     Transaction[]
  pilotEvents                      PilotEvent[]
  pilotFeedback                    PilotFeedback[]

  @@unique([leagueId, year])
  @@index([leagueId, status])
  @@index([sourceSeasonId])
}

model Owner {
  id        String   @id @default(cuid())
  userId    String?  @unique
  name      String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  teams        Team[]
  leagueInvites LeagueInvite[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  platformRole PlatformRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerProfile                  Owner?
  authSessions                  AuthSession[]
  memberships                   LeagueMembership[]
  createdLeagueInvites          LeagueInvite[]         @relation("LeagueInviteInvitedByUser")
  initiatedPhaseTransitions     LeaguePhaseTransition[]  @relation("LeaguePhaseTransitionInitiator")
  teamMemberships               TeamMembership[]
  createdFranchiseTagUsages     FranchiseTagUsage[]      @relation("UserCreatedFranchiseTagUsages")
  decidedContractOptions        ContractOptionDecision[] @relation("UserDecidedContractOptions")
  createdDeadCapCharges         DeadCapCharge[]          @relation("UserCreatedDeadCapCharges")
  createdComplianceIssues       ComplianceIssue[]        @relation("UserCreatedComplianceIssues")
  complianceActions             ComplianceAction[]       @relation("UserComplianceActions")
  commissionerOverrides         CommissionerOverride[]   @relation("UserCommissionerOverrides")
  notifications                 Notification[]           @relation("UserNotifications")
  createdTradeProposals         TradeProposal[]          @relation("UserCreatedTradeProposals")
  submittedTradeProposals       TradeProposal[]          @relation("UserSubmittedTradeProposals")
  respondedTradeProposals       TradeProposal[]          @relation("UserRespondedTradeProposals")
  reviewedTradeProposals        TradeProposal[]          @relation("UserReviewedTradeProposals")
  createdTradeEvaluations       TradeEvaluation[]        @relation("UserCreatedTradeEvaluations")
  activityEvents                ActivityEvent[]          @relation("UserActivityEvents")
  createdDraftOrderEntries      DraftOrderEntry[]        @relation("UserCreatedDraftOrderEntries")
  actedDraftSelections          DraftSelection[]         @relation("UserActedDraftSelections")
  openedAuctionPoolEntries      AuctionPlayerPoolEntry[] @relation("UserOpenedAuctionPoolEntries")
  reopenedAuctionPoolEntries    AuctionPlayerPoolEntry[] @relation("UserReopenedAuctionPoolEntries")
  auctionBids                   AuctionBid[]             @relation("UserAuctionBids")
  createdAuctionAwards          AuctionAward[]           @relation("UserCreatedAuctionAwards")
  blindTieResolutions           AuctionBlindTieResolution[] @relation("UserBlindTieResolutions")
  requestedHostPlatformSyncJobs HostPlatformSyncJob[]    @relation("UserRequestedHostPlatformSyncJobs")
  requestedPlayerRefreshJobs    PlayerRefreshJob[]
  reviewedPlayerRefreshChanges  PlayerRefreshChange[]
  approvedPlayerIdentityMappings PlayerIdentityMapping[]
  resolvedSyncMismatches        SyncMismatch[]           @relation("UserResolvedSyncMismatches")
  sentPlatformInvites           PlatformInvite[]         @relation("PlatformInviteInvitedByUser")
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  userAgent  String?
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt, expiresAt])
}

model AuthMagicLink {
  id                   String   @id @default(cuid())
  email                String
  tokenHash            String   @unique
  purpose              String   @default("SIGN_IN")
  createdAt            DateTime @default(now())
  expiresAt            DateTime
  consumedAt           DateTime?
  requestedByIp        String?
  requestedByUserAgent String?

  @@index([email, expiresAt])
  @@index([consumedAt, expiresAt])
}

model LeagueInvite {
  id                    String              @id @default(cuid())
  leagueId              String
  email                 String
  intendedRole          LeagueRole
  teamId                String?
  ownerId               String?
  tokenHash             String              @unique
  createdAt             DateTime            @default(now())
  expiresAt             DateTime
  acceptedAt            DateTime?
  revokedAt             DateTime?
  invitedByUserId       String?
  lastDeliveryAttemptedAt DateTime?
  lastDeliveryState     InviteDeliveryState?
  lastDeliveryErrorCode String?

  league        League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team          Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  owner         Owner? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  invitedByUser User?  @relation("LeagueInviteInvitedByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([leagueId, email])
  @@index([acceptedAt, revokedAt, expiresAt])
  @@index([teamId])
  @@index([ownerId])
  @@index([invitedByUserId])
  @@index([lastDeliveryState, lastDeliveryAttemptedAt])
}

model PlatformInvite {
  id                      String               @id @default(cuid())
  email                   String
  tokenHash               String               @unique
  createdAt               DateTime             @default(now())
  expiresAt               DateTime
  acceptedAt              DateTime?
  revokedAt               DateTime?
  invitedByUserId         String?
  lastDeliveryAttemptedAt DateTime?
  lastDeliveryState       InviteDeliveryState?
  lastDeliveryErrorCode   String?

  invitedByUser User? @relation("PlatformInviteInvitedByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([acceptedAt, revokedAt, expiresAt])
  @@index([invitedByUserId])
  @@index([lastDeliveryState, lastDeliveryAttemptedAt])
}

model LeagueDeadline {
  id                  String      @id @default(cuid())
  leagueId            String
  seasonId            String
  phase               LeaguePhase
  deadlineType        String
  scheduledAt         DateTime
  sourceType          String
  reminderOffsetsJson Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  league           League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season           Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  complianceIssues ComplianceIssue[] @relation("DeadlineComplianceIssues")

  @@index([leagueId, seasonId, phase])
  @@index([scheduledAt])
}

model LeaguePhaseTransition {
  id                String           @id @default(cuid())
  leagueId          String
  seasonId          String
  fromPhase         LeaguePhase
  toPhase           LeaguePhase
  initiatedByUserId String?
  initiatedByType   String
  reason            String?
  transitionStatus  TransitionStatus @default(SUCCESS)
  occurredAt        DateTime         @default(now())
  createdAt         DateTime         @default(now())

  league          League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season          Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  initiatedByUser User?  @relation("LeaguePhaseTransitionInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([leagueId, seasonId])
  @@index([occurredAt])
  @@index([initiatedByUserId])
}

model LeagueMembership {
  id        String     @id @default(cuid())
  userId    String
  leagueId  String
  teamId    String?
  role      LeagueRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([userId, leagueId])
  @@index([leagueId, role])
  @@index([teamId])
}

model Team {
  id            String   @id @default(cuid())
  leagueId      String
  ownerId       String?
  name          String
  abbreviation  String?
  divisionLabel String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  league                      League                   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  owner                       Owner?                   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  leagueInvites               LeagueInvite[]
  memberships                 LeagueMembership[]
  teamMemberships             TeamMembership[]
  seasonStates                TeamSeasonState[]
  rosterSlots                 RosterSlot[]
  rosterAssignments           RosterAssignment[]
  contracts                   Contract[]
  capPenalties                CapPenalty[]
  franchiseTagUsages          FranchiseTagUsage[]
  contractOptionDecisions     ContractOptionDecision[]
  deadCapCharges              DeadCapCharge[]
  complianceIssues            ComplianceIssue[]        @relation("TeamComplianceIssues")
  commissionerOverrides       CommissionerOverride[]   @relation("TeamCommissionerOverrides")
  notifications               Notification[]           @relation("TeamNotifications")
  outgoingPicks               FuturePick[]             @relation("PickOriginalTeam")
  currentPicks                FuturePick[]             @relation("PickCurrentTeam")
  sentTrades                  Trade[]                  @relation("TradeTeamA")
  recvTrades                  Trade[]                  @relation("TradeTeamB")
  proposedTradeProposals      TradeProposal[]          @relation("TradeProposalProposerTeam")
  counterpartyTradeProposals  TradeProposal[]          @relation("TradeProposalCounterpartyTeam")
  draftOrderEntriesOwned      DraftOrderEntry[]        @relation("DraftOrderEntryOwningTeam")
  draftOrderEntriesSelecting  DraftOrderEntry[]        @relation("DraftOrderEntrySelectingTeam")
  draftOrderEntriesOriginal   DraftOrderEntry[]        @relation("DraftOrderEntryOriginalTeam")
  draftPicks                  DraftPick[]              @relation("DraftPickSelectingTeam")
  draftSelections             DraftSelection[]         @relation("DraftSelectionTeam")
  nominatedAuctionPoolEntries AuctionPlayerPoolEntry[] @relation("AuctionPoolEntryNominatingTeam")
  leadingAuctionPoolEntries   AuctionPlayerPoolEntry[] @relation("AuctionPoolEntryLeadingTeam")
  auctionBids                 AuctionBid[]             @relation("AuctionBidTeam")
  auctionAwards               AuctionAward[]           @relation("AuctionAwardTeam")
  syncMismatches              SyncMismatch[]           @relation("TeamSyncMismatches")
  tradeAssetsSent             TradeAsset[]             @relation("TradeAssetFromTeam")
  tradeAssetsReceived         TradeAsset[]             @relation("TradeAssetToTeam")
  activityEvents              ActivityEvent[]          @relation("PrimaryTeamActivityEvents")
  relatedActivityEvents       ActivityEvent[]          @relation("RelatedTeamActivityEvents")
  transactions                Transaction[]
}

model Player {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  sourceKey      String?
  sourcePlayerId String?
  name           String
  displayName    String   @default("")
  searchName     String   @default("")
  position       Position
  nflTeam        String?
  age            Int?
  yearsPro       Int?
  injuryStatus   String?
  statusCode     String?
  statusText     String?
  isRestricted   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rosterSlots              RosterSlot[]
  rosterAssignments        RosterAssignment[]
  contracts                Contract[]
  capPenalties             CapPenalty[]
  franchiseTagUsages       FranchiseTagUsage[]
  contractOptionDecisions  ContractOptionDecision[]
  deadCapCharges           DeadCapCharge[]
  complianceIssues         ComplianceIssue[]        @relation("PlayerComplianceIssues")
  draftSelections          DraftSelection[]
  auctionPlayerPoolEntries AuctionPlayerPoolEntry[] @relation("PlayerAuctionPlayerPoolEntries")
  auctionPlayerPoolExclusions AuctionPlayerPoolExclusion[] @relation("PlayerAuctionPlayerPoolExclusions")
  auctionAwards            AuctionAward[]           @relation("AuctionAwardPlayer")
  syncMismatches           SyncMismatch[]           @relation("PlayerSyncMismatches")
  refreshChanges           PlayerRefreshChange[]
  seasonSnapshots          PlayerSeasonSnapshot[]
  identityMappings         PlayerIdentityMapping[]
  tradeAssets              TradeAsset[]
  activityEvents           ActivityEvent[]          @relation("PlayerActivityEvents")
  transactions             Transaction[]

  @@unique([sourceKey, sourcePlayerId])
  @@index([searchName])
}

model PlayerIdentityMapping {
  id               String   @id @default(cuid())
  playerId         String
  sourceKey        String
  sourcePlayerId   String
  approvedByUserId String?
  notes            String?
  approvedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  player         Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  approvedByUser User?  @relation(fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceKey, sourcePlayerId])
  @@index([playerId])
  @@index([approvedByUserId])
}

model PlayerRefreshJob {
  id                String                 @id @default(cuid())
  leagueId          String
  seasonId          String
  requestedByUserId String?
  adapterKey        String
  sourceLabel       String?
  status            PlayerRefreshJobStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  payloadDigest     String?
  inputJson         Json?
  summaryJson       Json?
  errorJson         Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  league          League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season          Season                @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  requestedByUser User?                 @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  changes         PlayerRefreshChange[]
  snapshots       PlayerSeasonSnapshot[]

  @@index([leagueId, seasonId, status])
  @@index([requestedByUserId])
  @@index([createdAt])
}

model PlayerSeasonSnapshot {
  id             String   @id @default(cuid())
  playerId       String
  leagueId       String
  seasonId       String
  refreshJobId   String?
  sourceKey      String?
  sourcePlayerId String?
  externalId     String?
  name           String
  displayName    String
  searchName     String
  position       Position
  nflTeam        String?
  age            Int?
  yearsPro       Int?
  injuryStatus   String?
  statusCode     String?
  statusText     String?
  isRestricted   Boolean  @default(false)
  capturedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  player         Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  league         League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season         Season                @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  refreshJob     PlayerRefreshJob?     @relation(fields: [refreshJobId], references: [id], onDelete: SetNull)
  refreshChanges PlayerRefreshChange[]

  @@unique([refreshJobId, playerId])
  @@index([leagueId, seasonId, playerId])
  @@index([playerId, capturedAt])
  @@index([refreshJobId])
}

model PlayerRefreshChange {
  id               String                         @id @default(cuid())
  leagueId         String
  seasonId         String
