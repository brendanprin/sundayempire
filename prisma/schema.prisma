  bids               AuctionBid[]  @relation("AuctionPlayerPoolEntryBids")
  award              AuctionAward? @relation("AuctionPlayerPoolEntryAward")
  blindTieResolution AuctionBlindTieResolution? @relation("PoolEntryBlindTieResolutions")

  @@unique([draftId, playerId])
  @@index([draftId, status, openBidClosesAt])
  @@index([draftId, status, blindBidClosesAt])
  @@index([currentLeadingTeamId])
}

model AuctionPlayerPoolExclusion {
  id                String                    @id @default(cuid())
  draftId           String
  leagueId          String
  seasonId          String
  playerId          String
  reason            AuctionPoolExclusionReason
  reasonDetailsJson Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  draft   Draft  @relation("DraftAuctionPlayerPoolExclusions", fields: [draftId], references: [id], onDelete: Cascade)
  league  League @relation("LeagueAuctionPlayerPoolExclusions", fields: [leagueId], references: [id], onDelete: Cascade)
  season  Season @relation("SeasonAuctionPlayerPoolExclusions", fields: [seasonId], references: [id], onDelete: Cascade)
  player  Player @relation("PlayerAuctionPlayerPoolExclusions", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftId, playerId])
  @@index([draftId, reason])
  @@index([playerId])
}

model AuctionBid {
  id            String           @id @default(cuid())
  draftId       String
  leagueId      String
  seasonId      String
  poolEntryId   String
  biddingTeamId String
  bidderUserId  String?
  bidType       AuctionBidType
  salaryAmount  Int
  contractYears Int
  status        AuctionBidStatus @default(ACTIVE)
  submittedAt   DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  draft       Draft                  @relation("DraftAuctionBids", fields: [draftId], references: [id], onDelete: Cascade)
  league      League                 @relation("LeagueAuctionBids", fields: [leagueId], references: [id], onDelete: Cascade)
  season      Season                 @relation("SeasonAuctionBids", fields: [seasonId], references: [id], onDelete: Cascade)
  poolEntry   AuctionPlayerPoolEntry @relation("AuctionPlayerPoolEntryBids", fields: [poolEntryId], references: [id], onDelete: Cascade)
  biddingTeam Team                   @relation("AuctionBidTeam", fields: [biddingTeamId], references: [id], onDelete: Cascade)
  bidderUser  User?                  @relation("UserAuctionBids", fields: [bidderUserId], references: [id], onDelete: SetNull)
  award       AuctionAward?          @relation("AuctionAwardWinningBid")
  blindTieResolution AuctionBlindTieResolution? @relation("BlindTieResolutionWinningBid")

  @@index([poolEntryId, bidType, status, submittedAt])
  @@index([biddingTeamId, submittedAt])
  @@index([draftId, submittedAt])
}

model AuctionAward {
  id                 String             @id @default(cuid())
  draftId            String
  leagueId           String
  seasonId           String
  poolEntryId        String
  winningBidId       String?
  awardedTeamId      String
  playerId           String
  contractId         String?
  rosterAssignmentId String?
  salaryAmount       Int
  contractYears      Int
  acquisitionType    AcquisitionType    @default(AUCTION)
  status             AuctionAwardStatus @default(FINALIZED)
  createdByUserId    String?
  awardedAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  draft            Draft                  @relation("DraftAuctionAwards", fields: [draftId], references: [id], onDelete: Cascade)
  league           League                 @relation("LeagueAuctionAwards", fields: [leagueId], references: [id], onDelete: Cascade)
  season           Season                 @relation("SeasonAuctionAwards", fields: [seasonId], references: [id], onDelete: Cascade)
  poolEntry        AuctionPlayerPoolEntry @relation("AuctionPlayerPoolEntryAward", fields: [poolEntryId], references: [id], onDelete: Cascade)
  winningBid       AuctionBid?            @relation("AuctionAwardWinningBid", fields: [winningBidId], references: [id], onDelete: SetNull)
  awardedTeam      Team                   @relation("AuctionAwardTeam", fields: [awardedTeamId], references: [id], onDelete: Cascade)
  player           Player                 @relation("AuctionAwardPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  contract         Contract?              @relation("AuctionAwardContract", fields: [contractId], references: [id], onDelete: SetNull)
  rosterAssignment RosterAssignment?      @relation("AuctionAwardRosterAssignment", fields: [rosterAssignmentId], references: [id], onDelete: SetNull)
  createdByUser    User?                  @relation("UserCreatedAuctionAwards", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([poolEntryId])
  @@unique([winningBidId])
  @@index([draftId, awardedAt])
  @@index([awardedTeamId, awardedAt])
  @@index([playerId])
}

model AuctionBlindTieResolution {
  id              String   @id @default(cuid())
  draftId         String
  leagueId        String
  seasonId        String
  poolEntryId     String
  tiedBidIds      String   // JSON array of tied bid IDs
  drawSeed        String   // Random seed used for draw
  drawResult      String   // JSON with draw details
  winningBidId    String   @unique
  resolvedAt      DateTime @default(now())
  resolvedByUserId String?

  draft         Draft                  @relation("DraftBlindTieResolutions", fields: [draftId], references: [id], onDelete: Cascade)
  league        League                 @relation("LeagueBlindTieResolutions", fields: [leagueId], references: [id], onDelete: Cascade)
  season        Season                 @relation("SeasonBlindTieResolutions", fields: [seasonId], references: [id], onDelete: Cascade)
  poolEntry     AuctionPlayerPoolEntry @relation("PoolEntryBlindTieResolutions", fields: [poolEntryId], references: [id], onDelete: Cascade)
  winningBid    AuctionBid             @relation("BlindTieResolutionWinningBid", fields: [winningBidId], references: [id], onDelete: Cascade)
  resolvedByUser User?                  @relation("UserBlindTieResolutions", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([poolEntryId])
  @@index([draftId, resolvedAt])
}

model HostPlatformSyncJob {
  id                String                    @id @default(cuid())
  leagueId          String
  seasonId          String
  requestedByUserId String?
  jobType           HostPlatformSyncJobType
  status            HostPlatformSyncJobStatus @default(PENDING)
  trigger           HostPlatformSyncTrigger
  adapterKey        String
  sourceLabel       String?
  sourceSnapshotAt  DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  payloadDigest     String?
  inputJson         Json?
  summaryJson       Json?
  errorJson         Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  league          League         @relation("LeagueHostPlatformSyncJobs", fields: [leagueId], references: [id], onDelete: Cascade)
  season          Season         @relation("SeasonHostPlatformSyncJobs", fields: [seasonId], references: [id], onDelete: Cascade)
  requestedByUser User?          @relation("UserRequestedHostPlatformSyncJobs", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  mismatches      SyncMismatch[] @relation("HostPlatformSyncJobMismatches")

  @@index([leagueId, seasonId, jobType, status, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([status, createdAt])
  @@index([adapterKey, createdAt])
}

model SyncMismatch {
  id                      String                      @id @default(cuid())
  leagueId                String
  seasonId                String
  jobId                   String
  teamId                  String?
  playerId                String?
  rosterAssignmentId      String?
  complianceIssueId       String?
  mismatchType            SyncMismatchType
  severity                SyncMismatchSeverity
  status                  SyncMismatchStatus          @default(OPEN)
  resolutionType          SyncMismatchResolutionType?
  fingerprint             String
  title                   String
  message                 String
  hostPlatformReferenceId String?
  hostValueJson           Json?
  dynastyValueJson        Json?
  metadataJson            Json?
  detectionCount          Int                         @default(1)
  firstDetectedAt         DateTime                    @default(now())
  lastDetectedAt          DateTime                    @default(now())
  resolvedAt              DateTime?
  resolvedByUserId        String?
  resolutionReason        String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  league           League              @relation("LeagueSyncMismatches", fields: [leagueId], references: [id], onDelete: Cascade)
  season           Season              @relation("SeasonSyncMismatches", fields: [seasonId], references: [id], onDelete: Cascade)
  job              HostPlatformSyncJob @relation("HostPlatformSyncJobMismatches", fields: [jobId], references: [id], onDelete: Cascade)
  team             Team?               @relation("TeamSyncMismatches", fields: [teamId], references: [id], onDelete: SetNull)
  player           Player?             @relation("PlayerSyncMismatches", fields: [playerId], references: [id], onDelete: SetNull)
  rosterAssignment RosterAssignment?   @relation("RosterAssignmentSyncMismatches", fields: [rosterAssignmentId], references: [id], onDelete: SetNull)
  complianceIssue  ComplianceIssue?    @relation("ComplianceIssueSyncMismatches", fields: [complianceIssueId], references: [id], onDelete: SetNull)
  resolvedByUser   User?               @relation("UserResolvedSyncMismatches", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([leagueId, seasonId, status, severity, lastDetectedAt])
  @@index([jobId, severity])
  @@index([teamId, status, severity])
  @@index([playerId, status, severity])
  @@index([fingerprint, status])
  @@index([rosterAssignmentId])
  @@index([complianceIssueId])
}

model Trade {
  id          String      @id @default(cuid())
  leagueId    String
  seasonId    String
  teamAId     String
  teamBId     String
  status      TradeStatus @default(PROPOSED)
  proposedAt  DateTime    @default(now())
  processedAt DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamA  Team         @relation("TradeTeamA", fields: [teamAId], references: [id], onDelete: Cascade)
  teamB  Team         @relation("TradeTeamB", fields: [teamBId], references: [id], onDelete: Cascade)
  assets TradeAsset[] @relation("LegacyTradeAssets")

  @@index([seasonId, status])
}

model TradeProposal {
  id                            String              @id @default(cuid())
  leagueId                      String
  seasonId                      String
  proposerTeamId                String
  counterpartyTeamId            String
  createdByUserId               String
  submittedByUserId             String?
  counterpartyRespondedByUserId String?
  reviewedByUserId              String?
  status                        TradeProposalStatus @default(DRAFT)
  submittedAt                   DateTime?
  counterpartyRespondedAt       DateTime?
  reviewedAt                    DateTime?
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt

  league           League            @relation("LeagueTradeProposals", fields: [leagueId], references: [id], onDelete: Cascade)
  season           Season            @relation("SeasonTradeProposals", fields: [seasonId], references: [id], onDelete: Cascade)
  proposerTeam     Team              @relation("TradeProposalProposerTeam", fields: [proposerTeamId], references: [id], onDelete: Cascade)
  counterpartyTeam Team              @relation("TradeProposalCounterpartyTeam", fields: [counterpartyTeamId], references: [id], onDelete: Cascade)
  createdByUser    User              @relation("UserCreatedTradeProposals", fields: [createdByUserId], references: [id], onDelete: Cascade)
  submittedByUser  User?             @relation("UserSubmittedTradeProposals", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  respondedByUser  User?             @relation("UserRespondedTradeProposals", fields: [counterpartyRespondedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser   User?             @relation("UserReviewedTradeProposals", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  assets           TradeAsset[]      @relation("TradeProposalAssets")
  evaluations      TradeEvaluation[] @relation("TradeProposalEvaluations")

  @@index([leagueId, seasonId, status])
  @@index([proposerTeamId, updatedAt])
  @@index([counterpartyTeamId, updatedAt])
  @@index([status, updatedAt])
}

model TradeAsset {
  id              String         @id @default(cuid())
  tradeId         String?
  tradeProposalId String?
  fromTeamId      String
  toTeamId        String
  assetType       TradeAssetType
  playerId        String?
  futurePickId    String?
  contractId      String?
  assetOrder      Int            @default(0)
  snapshotLabel   String?
  createdAt       DateTime       @default(now())

  trade         Trade?         @relation("LegacyTradeAssets", fields: [tradeId], references: [id], onDelete: Cascade)
  tradeProposal TradeProposal? @relation("TradeProposalAssets", fields: [tradeProposalId], references: [id], onDelete: Cascade)
  fromTeam      Team           @relation("TradeAssetFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam        Team           @relation("TradeAssetToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  player        Player?        @relation(fields: [playerId], references: [id], onDelete: SetNull)
  futurePick    FuturePick?    @relation(fields: [futurePickId], references: [id], onDelete: SetNull)
  contract      Contract?      @relation("TradeAssetContract", fields: [contractId], references: [id], onDelete: SetNull)

  @@index([tradeId, assetOrder])
  @@index([tradeProposalId, assetOrder])
  @@index([fromTeamId, toTeamId])
  @@index([playerId])
  @@index([futurePickId])
  @@index([contractId])
}

model TradeEvaluation {
  id                      String                 @id @default(cuid())
  proposalId              String
  leagueId                String
  seasonId                String
  createdByUserId         String?
  trigger                 TradeEvaluationTrigger
  outcome                 TradeEvaluationOutcome
  isCurrent               Boolean                @default(true)
  isSubmissionSnapshot    Boolean                @default(false)
  assetFingerprint        String
  findingsJson            Json
  remediationJson         Json?
  postTradeProjectionJson Json
  evaluatedAt             DateTime               @default(now())
  createdAt               DateTime               @default(now())

  proposal      TradeProposal @relation("TradeProposalEvaluations", fields: [proposalId], references: [id], onDelete: Cascade)
  league        League        @relation("LeagueTradeEvaluations", fields: [leagueId], references: [id], onDelete: Cascade)
  season        Season        @relation("SeasonTradeEvaluations", fields: [seasonId], references: [id], onDelete: Cascade)
  createdByUser User?         @relation("UserCreatedTradeEvaluations", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([proposalId, isCurrent])
  @@index([leagueId, seasonId, outcome])
  @@index([evaluatedAt])
}

model Transaction {
  id        String          @id @default(cuid())
  leagueId  String
  seasonId  String
  teamId    String?
  playerId  String?
  type      TransactionType
  summary   String
  metadata  Json?
  createdAt DateTime        @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([seasonId, createdAt])
}

model ActivityEvent {
  id               String   @id @default(cuid())
  leagueId         String
  seasonId         String
  actorUserId      String?
  teamId           String?
  relatedTeamId    String?
  playerId         String?
  eventType        String
  title            String
  body             String
  sourceEntityType String?
  sourceEntityId   String?
  dedupeKey        String?  @unique
  payload          Json?
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  league      League  @relation("LeagueActivityEvents", fields: [leagueId], references: [id], onDelete: Cascade)
  season      Season  @relation("SeasonActivityEvents", fields: [seasonId], references: [id], onDelete: Cascade)
  actorUser   User?   @relation("UserActivityEvents", fields: [actorUserId], references: [id], onDelete: SetNull)
  team        Team?   @relation("PrimaryTeamActivityEvents", fields: [teamId], references: [id], onDelete: SetNull)
  relatedTeam Team?   @relation("RelatedTeamActivityEvents", fields: [relatedTeamId], references: [id], onDelete: SetNull)
  player      Player? @relation("PlayerActivityEvents", fields: [playerId], references: [id], onDelete: SetNull)

  @@index([leagueId, seasonId, occurredAt])
  @@index([leagueId, eventType, occurredAt])
  @@index([teamId, occurredAt])
  @@index([relatedTeamId, occurredAt])
  @@index([playerId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([sourceEntityType, sourceEntityId])
}

model PilotEvent {
  id            String      @id @default(cuid())
  leagueId      String
  seasonId      String?
  actorEmail    String?
  actorRole     LeagueRole?
  actorTeamId   String?
  eventType     String
  eventCategory String
  eventStep     String?
  status        String?
  entityType    String?
  entityId      String?
  pagePath      String?
  requestPath   String?
  requestMethod String?
  context       Json?
  createdAt     DateTime    @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([leagueId, createdAt])
  @@index([leagueId, eventCategory, createdAt])
  @@index([leagueId, eventType, createdAt])
}

model PilotFeedback {
  id               String      @id @default(cuid())
  leagueId         String
  seasonId         String?
  actorEmail       String?
  actorRole        LeagueRole?
  actorTeamId      String?
  category         String
  severity         String
  pagePath         String
  pageTitle        String?
  message          String
  stepsToReproduce String?
  status           String      @default("NEW")
  metadata         Json?
  createdAt        DateTime    @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([leagueId, status, createdAt])
  @@index([leagueId, category, createdAt])
  @@index([actorEmail, createdAt])
}

model NotificationReadState {
  id         String   @id @default(cuid())
  leagueId   String
  actorEmail String
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, actorEmail])
  @@index([actorEmail, leagueId])
}
